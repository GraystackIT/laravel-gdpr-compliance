{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "graystackit/laravel-gdpr-compliance",
    "description": "GDPR/DSGVO compliance toolkit for Laravel applications: consent, data export, erasure, legal hold, audit logging and package inventory.",
    "keywords": [
        "laravel",
        "gdpr",
        "dsgvo",
        "privacy",
        "compliance",
        "consent",
        "data-protection"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/graystackit/laravel-gdpr-compliance",
    "support": {
        "issues": "https://github.com/graystackit/laravel-gdpr-compliance/issues",
        "source": "https://github.com/graystackit/laravel-gdpr-compliance"
    },
    "authors": [
        {
            "name": "Bernhard Harb",
            "email": "bernhard@graystackit.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/notifications": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "GraystackIt\\Gdpr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraystackIt\\Gdpr\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:compact": "vendor/bin/pest --compact",
        "pint": "vendor/bin/pint --format=agent",
        "pint:dirty": "vendor/bin/pint --dirty --format=agent"
    },
    "extra": {
        "laravel": {
            "providers": [
                "GraystackIt\\Gdpr\\GdprServiceProvider"
            ],
            "aliases": {
                "GDPR": "GraystackIt\\Gdpr\\Facades\\GDPR"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
